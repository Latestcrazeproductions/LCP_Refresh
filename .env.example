# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://qsccsddknmvidvcfpffu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ApCzT3HvnB5AEvKYilq3BA_D1K8QHwq

# Contact form email — SMTP via Nodemailer (any standard provider). Set in Vercel / .env.local only.
# If SMTP_HOST=smtp.resend.com, errors come from Resend’s servers (verify domain in Resend or use DreamHost below).

# DreamHost — use a mailbox you created in the DreamHost panel for your domain (same domain as the site).
# SMTP_HOST=smtp.dreamhost.com
# SMTP_PORT=465
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your-dreamhost-mailbox-password
# MAIL_FROM_EMAIL=noreply@yourdomain.com
# MAIL_FROM_NAME=Latest Craze Productions
# (Port 587 + TLS also works: SMTP_PORT=587)

# Google Workspace / Gmail — App Password or admin SMTP policy
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your-app-password
# MAIL_FROM_EMAIL=noreply@yourdomain.com
# MAIL_FROM_NAME=Latest Craze Productions

# Required for Vercel production (sitemap, robots, emails)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Semrush Report API — for CMS SemRush Reports (default: http://127.0.0.1:5001)
NEXT_PUBLIC_SEMRUSH_API_URL=http://127.0.0.1:5001

# Set to "true" to enable SemRush Reports in the CMS (leave unset for Coming Soon)
# NEXT_PUBLIC_SEMRUSH_ENABLED=true

# Internal Forms — each form can populate a Google Sheet via Apps Script web app
# See docs/FORMS_GOOGLE_SHEETS.md for setup. Deploy from each sheet and paste URLs.
# GOOGLE_SHEETS_INVOICE_REQUEST_URL=https://script.google.com/macros/s/xxxx/exec
# GOOGLE_SHEETS_PM_COORDINATOR_URL=https://script.google.com/macros/s/xxxx/exec
# GOOGLE_SHEETS_PAYABLES_URL=https://script.google.com/macros/s/xxxx/exec
# GOOGLE_SHEETS_ATTENDANCE_URL=https://script.google.com/macros/s/xxxx/exec

# LASSO contacts sync (cron) — for nightly pull into invoice_contacts
# See docs/LASSO_CONTACTS_CRON.md
# LASSO_API_URL=https://api.lasso.io
# LASSO_API_KEY=your-api-key
# LASSO_CONTACTS_ENDPOINT=/v1/contacts   # or full URL to your LASSO contacts endpoint

# Supabase Service Role — server-only. Used to read CMS Settings (staff inquiry emails) when the contact form posts; never expose to the client.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
